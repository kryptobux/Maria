# mariaschroeder.com — static Next.js export on Strato (Apache)
# Lands in out/ via public/ and is uploaded together with the site.

AddDefaultCharset utf-8

# Compression — without this, Lighthouse loses ~400 KiB of transfer savings
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/xml application/xml font/woff2
</IfModule>

# Long-lived caching for hashed/immutable assets; HTML always revalidates
<IfModule mod_expires.c>
  ExpiresActive on
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

ErrorDocument 404 /404.html

# HTTPS erzwingen — ERST aktivieren (auskommentieren entfernen), nachdem
# SSL für mariaschroeder.com im Strato-Panel eingeschaltet ist (DEPLOY.md §3),
# sonst Redirect auf eine Domain ohne gültiges Zertifikat.
# <IfModule mod_rewrite.c>
#   RewriteEngine On
#   RewriteCond %{HTTPS} !=on
#   RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
# </IfModule>
